# Copy to .env.local and fill in. These are read server-side by the token route.
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=APIxxxxxxxxxxxx
LIVEKIT_API_SECRET=your_livekit_api_secret

# Exposed to the browser so the client knows which ws URL to connect to.
NEXT_PUBLIC_LIVEKIT_URL=wss://your-project.livekit.cloud

# Default room both the caller and the monitor join.
NEXT_PUBLIC_DEFAULT_ROOM=voice-agent-room
