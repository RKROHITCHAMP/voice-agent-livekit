# ============================================================
#  Backend environment variables  (copy to .env and fill in)
# ============================================================

# ---- LiveKit (https://cloud.livekit.io  ->  Settings -> Keys) ----
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=APIxxxxxxxxxxxx
LIVEKIT_API_SECRET=your_livekit_api_secret

# ---- LLM: OpenAI (https://platform.openai.com/api-keys) ----
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxx
# Model used for conversation, intent detection and summaries
LLM_MODEL=gpt-4o-mini

# ---- STT + TTS: Deepgram (https://console.deepgram.com) ----
DEEPGRAM_API_KEY=your_deepgram_api_key
# Deepgram STT model + Deepgram Aura TTS voice
STT_MODEL=nova-3
TTS_VOICE=aura-2-thalia-en

# ---- Twilio warm-transfer (https://console.twilio.com) ----
# The LiveKit SIP OUTBOUND trunk id created with `lk sip outbound create`.
# This is the LiveKit-side id (starts with ST_...), NOT the Twilio trunk SID.
SIP_OUTBOUND_TRUNK_ID=ST_xxxxxxxxxxxx
# E.164 number of the human agent the call is warm-transferred to.
HUMAN_AGENT_NUMBER=+15105550123

# ---- App config ----
# Name of the SQLite file that stores appointments (created automatically).
APPOINTMENTS_DB=appointments.db
# Default room the dev caller joins (frontend uses the same default).
DEFAULT_ROOM=voice-agent-room
