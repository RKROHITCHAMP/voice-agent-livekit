# ============================================================
#  Backend environment variables  (copy to .env and fill in)
# ============================================================

# ---- LiveKit (https://cloud.livekit.io  ->  Settings -> Keys) ----
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=APIxxxxxxxxxxxx
LIVEKIT_API_SECRET=your_livekit_api_secret

# ---- LLM provider: "groq" (default, free, no card) or "openai" ----
LLM_PROVIDER=groq

# Groq (https://console.groq.com/keys) — used when LLM_PROVIDER=groq
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxx
# Model for conversation, intent detection and summaries.
#   Groq:   llama-3.3-70b-versatile  (good tool-calling) or llama-3.1-8b-instant
#   OpenAI: gpt-4o-mini
LLM_MODEL=llama-3.3-70b-versatile

# OpenAI (https://platform.openai.com/api-keys) — used only when LLM_PROVIDER=openai
# OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxx

# ---- STT + TTS: Deepgram (https://console.deepgram.com) ----
DEEPGRAM_API_KEY=your_deepgram_api_key
# Deepgram STT model + Deepgram Aura TTS voice
STT_MODEL=nova-3
TTS_VOICE=aura-2-thalia-en

# ---- Twilio warm-transfer (https://console.twilio.com) ----
# The LiveKit SIP OUTBOUND trunk id created with `lk sip outbound create`.
# This is the LiveKit-side id (starts with ST_...), NOT the Twilio trunk SID.
SIP_OUTBOUND_TRUNK_ID=ST_xxxxxxxxxx